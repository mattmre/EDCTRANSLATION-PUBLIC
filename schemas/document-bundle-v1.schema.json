{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:edc-translation:schemas:document-bundle-v1",
  "title": "EDC DocumentBundle v1",
  "description": "Versioned OCR-to-translation bundle produced by the OCR side and consumed by the translation side.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "document-bundle-v1"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "source_file_name": {
      "type": "string",
      "minLength": 1
    },
    "source_file_sha256": {
      "$ref": "#/definitions/sha256"
    },
    "source_ocr_sha256": {
      "$ref": "#/definitions/sha256"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/page"
      }
    },
    "spans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/span"
      }
    },
    "language_metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "primary_language": {
          "type": "string",
          "minLength": 1
        },
        "detected_languages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source": {
          "type": "string"
        }
      }
    },
    "ocr_engine_metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "engine_id": {
          "type": "string",
          "minLength": 1
        },
        "engine_version": {
          "type": "string"
        },
        "pipeline_version": {
          "type": "string"
        }
      },
      "required": ["engine_id"]
    },
    "custody_chain_head": {
      "type": "string",
      "minLength": 1
    },
    "artifact_manifest": {
      "$ref": "#/definitions/artifact_manifest"
    },
    "page_image_references": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/artifact"
      }
    },
    "page_previews": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/artifact"
      }
    },
    "layout_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "detected_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "privilege_flags": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "tenant_policy_hash": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schema_version",
    "document_id",
    "source_file_name",
    "source_file_sha256",
    "source_ocr_sha256",
    "pages",
    "spans",
    "language_metadata",
    "ocr_engine_metadata",
    "custody_chain_head",
    "artifact_manifest"
  ],
  "definitions": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "bbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number"
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "page_number": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string"
        },
        "span_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": ["page_number", "span_ids"]
    },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "span_id": {
          "type": "string",
          "minLength": 1
        },
        "page_number": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string"
        },
        "bbox": {
          "$ref": "#/definitions/bbox"
        },
        "bboxes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/bbox"
          }
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["span_id", "page_number", "text", "bbox", "bboxes"]
    },
    "artifact_manifest": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/artifact"
          }
        }
      },
      "required": ["artifacts"]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/definitions/sha256"
        },
        "mime_type": {
          "type": "string"
        }
      },
      "required": ["artifact_id", "artifact_type"]
    }
  }
}
