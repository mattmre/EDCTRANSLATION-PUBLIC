# EDC_TRANSLATION optional live-provider and local development configuration.
# Keep live smokes disabled unless you explicitly intend to call a provider.

EDC_TRANSLATION_LIVE_SMOKE=0

# Auth/security configuration. Keep disabled for isolated local use
# until API middleware enforcement is intentionally configured.
EDC_AUTH_MODE=disabled
EDC_JWT_SECRET=
EDC_LDAP_URL=
EDC_LDAP_USER_SEARCH_BASE=
EDC_LDAP_GROUP_SEARCH_BASE=
EDC_LDAP_BIND_DN=
EDC_LDAP_BIND_PASSWORD=
EDC_STATIC_API_TOKEN_HASH=
EDC_STATIC_API_TOKEN_TENANT=standalone
EDC_STATIC_API_TOKEN_SCOPES=translation:read,translation:submit,models:read,evidence:read
EDC_STATIC_API_TOKEN_SUBJECT=local-static-token

# Local OpenAI-compatible endpoint, such as vLLM, LM Studio, llama.cpp server,
# or another local service that implements /v1/models and /v1/chat/completions.
EDC_TRANSLATION_LOCAL_LLM_BASE_URL=http://127.0.0.1:1234
EDC_TRANSLATION_LOCAL_LLM_MODEL_IDS=

# Optional Facebook fastText language identification model, for example
# lid.176.bin or lid.176.ftz. If unset, EDC_TRANSLATION falls back to a local
# heuristic detector for source_language=auto.
EDC_TRANSLATION_FASTTEXT_LID_MODEL=

# OpenRouter. Live smoke discovery prefers free models when model IDs are not
# configured. Normal translation requires explicit tenant policy approval.
OPENROUTER_API_KEY=
EDC_TRANSLATION_OPENROUTER_MODEL_IDS=

# Gemini API-key path. Vertex/ADC production hardening is intentionally separate.
GOOGLE_API_KEY=
GEMINI_API_KEY=
EDC_TRANSLATION_GOOGLE_MODEL_ID=
